# Application
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=vab_enterprise

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# Super Admin bootstrap password (used only on first run)
SUPER_ADMIN_PASSWORD=change-me-on-first-run

# SMTP (required for registration emails / OTP delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
